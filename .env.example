# Escolha o provider: gemini, openai, ou ollama
AI_PROVIDER=gemini

# Google Gemini (grátis — https://aistudio.google.com/apikey)
GEMINI_API_KEY=cole-sua-chave-aqui
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (pago — https://platform.openai.com/api-keys)
OPENAI_API_KEY=cole-sua-chave-aqui
OPENAI_MODEL=gpt-4o-mini

# Ollama local (grátis — https://ollama.ai)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

LANGUAGE=pt-BR
